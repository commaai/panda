import opendbc

env = Environment(
  CFLAGS=[
    '-nostdlib',
    '-fno-builtin',
    '-std=gnu11',
    '-Wfatal-errors',
    '-Wno-pointer-to-int-cast',
  ],
  CPPPATH=[".", "../../", "../../board/", opendbc.INCLUDE_PATH],
)

panda = env.SharedObject("panda.os", "panda.c")
libc = env.SharedObject("libc.os", "../../board/libc.c")
crc = env.SharedObject("crc.os", "../../board/crc.c")
provision = env.SharedObject("provision.os", "../../board/provision.c")
critical = env.SharedObject("critical.os", "../../board/sys/critical.c")
faults = env.SharedObject("faults.os", "../../board/sys/faults.c")
main_globals = env.SharedObject("main_globals.os", "../../board/main_globals.c")
libpanda = env.SharedLibrary("libpanda.so", [panda, libc, crc, provision, critical, faults, main_globals])
